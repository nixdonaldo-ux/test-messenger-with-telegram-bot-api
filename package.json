{
  "name": "messenger-telegram",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace server run start:dev\" \"npm --workspace client run dev\"",
    "start:server": "npm --workspace server run start",
    "start:client": "npm --workspace client run preview"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
